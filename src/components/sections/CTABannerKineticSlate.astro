---
import Container from '@/components/layout/Container.astro';
import Button from '@/components/ui/Button.astro';
import type { TemplateCta } from '@/types';

interface Props {
  cta: TemplateCta;
}

const { cta } = Astro.props;
---

<section class="border-b border-border py-24 sm:py-32">
  <Container>
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-accent px-6 py-16 text-center sm:px-12 sm:py-20">
      <div class="absolute inset-0 -z-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.2)_0%,transparent_40%)]"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -top-24 -left-24 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
      <div class="relative z-10">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{cta.title}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/90">{cta.subtitle}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          {cta.primaryCta && <Button href={cta.primaryCta.href} variant="secondary" size="lg">{cta.primaryCta.text}</Button>}
          {cta.secondaryCta && <Button href={cta.secondaryCta.href} variant="outline" size="lg" class="border-white/30 bg-white/10 text-white hover:bg-white/20">{cta.secondaryCta.text}</Button>}
        </div>
      </div>
    </div>
  </Container>
</section>
