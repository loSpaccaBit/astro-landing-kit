---
import Container from '@/components/layout/Container.astro';
import type { TemplateTestimonial } from '@/types';

interface Props {
  title: string;
  testimonials: TemplateTestimonial[];
}

const { title, testimonials } = Astro.props;
---

<section class="border-b border-border py-24 sm:py-32">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-medium leading-[1.15] text-foreground sm:text-5xl text-balance">{title}</h2>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        testimonials.map((testimonial, index) => (
          <blockquote class="animate-fade-up" style={`animation-delay: ${index * 100}ms;`}>
            <p class="text-2xl font-medium leading-snug text-foreground">"{testimonial.quote}"</p>
            <footer class="mt-6">
              <p class="text-sm font-medium uppercase tracking-widest text-muted-foreground">
                {testimonial.author} — {testimonial.role}{testimonial.company && `, ${testimonial.company}`}
              </p>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </Container>
</section>
