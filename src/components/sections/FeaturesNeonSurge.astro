---
import Container from '@/components/layout/Container.astro';
import type { TemplateFeature } from '@/types';

interface Props {
  title: string;
  description?: string;
  features: TemplateFeature[];
}

const { title, description, features } = Astro.props;
---

<section id="features" class="border-t border-border py-24 sm:py-32">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-normal tracking-tight text-foreground sm:text-5xl">{title}</h2>
      {description && <p class="mt-4 text-lg text-muted-foreground">{description}</p>}
    </div>

    <div class="mt-16 grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2">
      {
        features.map((feature, index) => (
          <div
            class="bg-background p-8 transition-colors hover:bg-muted sm:p-10 animate-fade-up"
            style={`animation-delay: ${index * 75}ms;`}
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-primary/30 bg-primary/10 text-primary">
              <span class="text-xl font-bold">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <h3 class="text-xl font-medium uppercase tracking-wide text-foreground">{feature.title}</h3>
            <p class="mt-3 text-muted-foreground">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
