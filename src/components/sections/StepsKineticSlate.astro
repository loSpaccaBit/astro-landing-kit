---
import Container from '@/components/layout/Container.astro';
import type { TemplateStep } from '@/types';

interface Props {
  title: string;
  steps: TemplateStep[];
}

const { title, steps } = Astro.props;
---

<section class="border-y border-border bg-muted/40 py-24 sm:py-32">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>
    </div>

    <div class="relative mt-16">
      <div class="absolute left-8 top-10 hidden h-0.5 w-[calc(100%-4rem)] bg-border md:block"></div>
      <div class="grid gap-10 md:grid-cols-3">
        {
          steps.map((step, index) => (
            <div class="relative animate-fade-up" style={`animation-delay: ${index * 100}ms;`}>
              <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-primary text-3xl font-bold text-primary-foreground shadow-lg shadow-primary/20">
                {index + 1}
              </div>
              <h3 class="text-xl font-semibold text-foreground">{step.title}</h3>
              <p class="mt-2 text-muted-foreground">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
