---
import Container from '@/components/layout/Container.astro';

interface Props {
  logos: string[];
}

const { logos } = Astro.props;
---

<section class="border-b border-border py-16">
  <Container>
    <div class="flex flex-col items-center justify-between gap-8 sm:flex-row">
      <p class="text-sm font-medium uppercase tracking-[0.15em] text-muted-foreground">
        Selected clients
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-5 sm:justify-end">
        {
          logos.map((logo) => (
            <div class="text-base font-medium text-muted-foreground transition-colors hover:text-foreground">
              {logo}
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
