---
import Container from '@/components/layout/Container.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import type { TemplatePricingTier } from '@/types';

interface Props {
  title: string;
  tiers: TemplatePricingTier[];
}

const { title, tiers } = Astro.props;
---

<section id="pricing" class="border-b border-border py-24 sm:py-32">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        tiers.map((tier, index) => (
          <Card
            class:list={['relative flex flex-col', tier.highlighted && 'bg-foreground text-background']}
            style={`animation-delay: ${index * 100}ms;`}
          >
            {tier.highlighted && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary-foreground">
                Most popular
              </span>
            )}
            <h3 class:list={['text-lg font-semibold', tier.highlighted ? 'text-background' : 'text-foreground']}>
              {tier.name}
            </h3>
            <div class:list={['mt-2 text-4xl font-bold', tier.highlighted ? 'text-background' : 'text-foreground']}>
              {tier.price}
            </div>
            <p class:list={['mt-2 text-sm', tier.highlighted ? 'text-background/70' : 'text-muted-foreground']}>
              {tier.description}
            </p>

            <ul class="mt-6 flex-1 space-y-3">
              {
                tier.features.map((feature) => (
                  <li class:list={['flex items-start gap-3 text-sm', tier.highlighted ? 'text-background/90' : 'text-muted-foreground']}>
                    <svg class:list={['mt-0.5 h-4 w-4 shrink-0', tier.highlighted ? 'text-primary' : 'text-primary']} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {feature}
                  </li>
                ))
              }
            </ul>

            <Button
              href="#"
              variant={tier.highlighted ? 'primary' : 'outline'}
              class:list={['mt-8 w-full']}
            >
              {tier.cta}
            </Button>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
