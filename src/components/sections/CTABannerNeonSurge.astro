---
import Container from '@/components/layout/Container.astro';
import Button from '@/components/ui/Button.astro';
import type { TemplateCta } from '@/types';

interface Props {
  cta: TemplateCta;
}

const { cta } = Astro.props;
---

<section class="border-b border-border py-24 sm:py-32">
  <Container>
    <div class="relative overflow-hidden rounded-2xl border border-primary/30 bg-muted px-6 py-16 text-center sm:px-12 sm:py-20">
      <div class="absolute inset-0 -z-0 bg-[radial-gradient(circle_at_50%_50%,var(--primary)_0%,transparent_60%)] opacity-10"></div>
      <div class="relative z-10">
        <h2 class="text-3xl font-normal tracking-tight text-foreground sm:text-5xl">{cta.title}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-muted-foreground">{cta.subtitle}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          {cta.primaryCta && <Button href={cta.primaryCta.href} size="lg" class="animate-glow">{cta.primaryCta.text}</Button>}
          {cta.secondaryCta && <Button href={cta.secondaryCta.href} variant="outline" size="lg">{cta.secondaryCta.text}</Button>}
        </div>
      </div>
    </div>
  </Container>
</section>
