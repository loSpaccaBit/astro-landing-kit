---
import Container from '@/components/layout/Container.astro';
import Card from '@/components/ui/Card.astro';
import type { TemplateFeature } from '@/types';

interface Props {
  title: string;
  description?: string;
  features: TemplateFeature[];
}

const { title, description, features } = Astro.props;

const iconClasses = [
  'bg-primary/10 text-primary',
  'bg-accent/10 text-accent',
  'bg-emerald-500/10 text-emerald-600',
  'bg-amber-500/10 text-amber-600',
  'bg-rose-500/10 text-rose-600',
  'bg-violet-500/10 text-violet-600',
];

const icons = [
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  'M12 19l9 2-9-18-9 18 9-2zm0 0v-8',
  'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
];
---

<section id="features" class="py-24 sm:py-32">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>
      {description && <p class="mt-4 text-lg text-muted-foreground">{description}</p>}
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, index) => (
          <Card class="group relative overflow-hidden animate-fade-up" style={`animation-delay: ${index * 50}ms;`}>
            <div class={`mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl ${iconClasses[index % iconClasses.length]}`}>
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={icons[index % icons.length]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-foreground">{feature.title}</h3>
            <p class="mt-2 text-muted-foreground">{feature.description}</p>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
