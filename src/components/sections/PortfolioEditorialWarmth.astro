---
import Container from '@/components/layout/Container.astro';
import { asset } from '@/utils/assets';

interface Project {
  title: string;
  category: string;
  image: string;
}

interface Props {
  title: string;
  projects?: Project[];
}

const { title, projects = [
  { title: 'Bloom Rebrand', category: 'Brand Identity', image: 'images/agency/portfolio-1.jpg' },
  { title: 'Northwind Platform', category: 'Web Design', image: 'images/agency/portfolio-2.jpg' },
  { title: 'Lumina App', category: 'Product Design', image: 'images/agency/portfolio-3.jpg' },
  { title: 'Evergreen Campaign', category: 'Art Direction', image: 'images/agency/portfolio-4.jpg' },
] } = Astro.props;

const displayProjects = projects.map((project) => ({
  ...project,
  image: asset(project.image),
}));
---

<section id="portfolio" class="border-b border-border py-24 sm:py-32">
  <Container>
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <h2 class="text-4xl font-medium leading-[1.15] text-foreground sm:text-5xl text-balance">{title}</h2>
      <a href="#" class="text-sm font-medium uppercase tracking-widest text-primary hover:underline">View all work</a>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {
        displayProjects.map((project, index) => (
          <a
            href="#"
            class="group relative aspect-[4/3] overflow-hidden bg-muted animate-fade-up"
            style={`animation-delay: ${index * 100}ms;`}
          >
            <img
              src={project.image}
              alt={project.title}
              width="800"
              height="600"
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-foreground/80 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-0 left-0 p-6 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <p class="text-xs uppercase tracking-widest">{project.category}</p>
              <h3 class="mt-1 text-2xl font-medium">{project.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </Container>
</section>
