---
import Container from '@/components/layout/Container.astro';
import Button from '@/components/ui/Button.astro';

import type { TemplateStat } from '@/types';

interface Props {
  title: string;
  subtitle: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  stats?: TemplateStat[];
}

const { title, subtitle, primaryCta, secondaryCta, stats = [] } = Astro.props;
---

<section class="relative border-b border-border py-20 sm:py-28">
  <Container class="relative z-10">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="animate-fade-up">
        <p class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-muted-foreground">
          Creative Studio
        </p>
        <h1 class="text-5xl font-medium leading-[1.1] text-foreground sm:text-6xl lg:text-7xl text-balance">
          {title}
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted-foreground text-balance">
          {subtitle}
        </p>

        {
          (primaryCta || secondaryCta) && (
            <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row">
              {primaryCta && <Button href={primaryCta.href} size="lg">{primaryCta.text}</Button>}
              {secondaryCta && (
                <Button href={secondaryCta.href} variant="ghost" size="lg">
                  {secondaryCta.text}
                </Button>
              )}
            </div>
          )
        }

        {
          stats.length > 0 && (
            <div class="mt-12 flex gap-12 animate-fade-up" style="animation-delay: 175ms;">
              {stats.map((stat) => (
                <div>
                  <div class="text-3xl font-medium text-foreground sm:text-4xl">{stat.value}</div>
                  <div class="mt-1 text-xs uppercase tracking-[0.15em] text-muted-foreground">{stat.label}</div>
                </div>
              ))}
            </div>
          )
        }
      </div>

      <div class="animate-fade-up" style="animation-delay: 150ms;">
        <div class="aspect-[4/5] overflow-hidden rounded-sm bg-muted">
          <img
            src="/images/agency/hero.jpg"
            alt="Creative studio workspace"
            width="800"
            height="1000"
            loading="eager"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </Container>
</section>
