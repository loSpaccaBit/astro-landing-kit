---
import Container from '@/components/layout/Container.astro';

interface Props {
  logos: string[];
}

const { logos } = Astro.props;
---

<section class="border-b border-border py-14">
  <Container>
    <p class="mb-8 text-center text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
      Featured in
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-14">
      {
        logos.map((logo) => (
          <div class="text-xl font-bold uppercase tracking-wider text-muted-foreground/60 transition-colors hover:text-primary">
            {logo}
          </div>
        ))
      }
    </div>
  </Container>
</section>
