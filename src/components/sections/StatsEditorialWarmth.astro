---
import Container from '@/components/layout/Container.astro';
import type { TemplateStat } from '@/types';

interface Props {
  stats: TemplateStat[];
}

const { stats } = Astro.props;
---

<section class="border-b border-border py-16">
  <Container>
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        stats.map((stat, index) => (
          <div class="animate-fade-up" style={`animation-delay: ${index * 100}ms;`}>
            <div class="text-4xl font-medium text-foreground sm:text-5xl">{stat.value}</div>
            <div class="mt-2 text-sm uppercase tracking-widest text-muted-foreground">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
