---
import Container from '@/components/layout/Container.astro';
import Button from '@/components/ui/Button.astro';

import type { TemplateStat } from '@/types';

interface Props {
  title: string;
  subtitle: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  stats?: TemplateStat[];
}

const { title, subtitle, primaryCta, secondaryCta, stats = [] } = Astro.props;
---

<section class="relative overflow-hidden border-b border-border py-20 sm:py-28 lg:py-32">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,var(--primary)_0%,transparent_45%)] opacity-10"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,var(--accent)_0%,transparent_40%)] opacity-10"></div>
    <div class="absolute left-0 top-0 h-full w-full bg-[linear-gradient(180deg,transparent_0%,var(--muted)_100%)] opacity-60"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="animate-fade-up">
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
          </span>
          Now in public beta
        </span>

        <h1 class="max-w-2xl text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl lg:text-6xl text-balance">
          {title}
        </h1>
        <p class="mt-6 max-w-lg text-lg text-muted-foreground sm:text-xl text-balance">
          {subtitle}
        </p>

        {
          (primaryCta || secondaryCta) && (
            <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row">
              {primaryCta && <Button href={primaryCta.href} size="lg">{primaryCta.text}</Button>}
              {secondaryCta && (
                <Button href={secondaryCta.href} variant="outline" size="lg">
                  {secondaryCta.text}
                </Button>
              )}
            </div>
          )
        }
      </div>

      <div class="relative animate-fade-up" style="animation-delay: 150ms;">
        <div class="relative mx-auto max-w-lg lg:max-w-none">
          <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-primary/20 to-accent/20 blur-2xl"></div>
          <img
            src="/images/saas/hero.jpg"
            alt="SaaS dashboard preview"
            width="1200"
            height="800"
            class="relative rounded-2xl border border-border bg-muted shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>

    {
      stats.length > 0 && (
        <div class="mt-16 grid gap-4 sm:mt-20 sm:grid-cols-3 animate-fade-up" style="animation-delay: 300ms;">
          {stats.map((stat) => (
            <div class="rounded-2xl border border-border bg-muted/60 p-6 text-center backdrop-blur-sm">
              <div class="text-3xl font-bold text-foreground sm:text-4xl">{stat.value}</div>
              <div class="mt-1 text-sm font-medium uppercase tracking-wide text-muted-foreground">{stat.label}</div>
            </div>
          ))}
        </div>
      )
    }
  </Container>
</section>
